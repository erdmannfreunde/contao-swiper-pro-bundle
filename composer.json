{
    "name": "erdmannfreunde/contao-swiper-pro-bundle",
    "description": "A Contao CMS extension for creating Swiper sliders with custom YAML configurations.",
    "keywords": ["contao", "swiper", "slider", "content-element"],
    "type": "contao-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Dennis Erdmann",
            "homepage": "https://erdmann-freunde.de"
        }
    ],
    "require": {
        "php": ">=8.2",
        "contao/core-bundle": "^5.3",
        "symfony/yaml": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "ErdmannFreunde\\ContaoSwiperProBundle\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "ErdmannFreunde\\ContaoSwiperProBundle\\ContaoManager\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "contao/manager-plugin": true,
            "contao-components/installer": true,
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "contao/easy-coding-standard": "^6.13"
    }
}
